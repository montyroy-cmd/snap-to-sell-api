# App
NODE_ENV=development
PORT=3000
API_VERSION=v1

# CORS — comma-separated origins (Flutter app + future web dashboard)
ALLOWED_ORIGINS=http://localhost:3000,https://your-flutter-web-domain.com

# Supabase
SUPABASE_URL=https://ecdeecosyfogplakolbg.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase Dashboard → Project Settings → API → JWT Secret (verify HS256 tokens)
SUPABASE_JWT_SECRET=

# Prisma / PostgreSQL (Supabase)
#
# DATABASE_URL — runtime. Options:
# - Transaction pooler (Dashboard → Connect): port 6543 + ?pgbouncer=true
#   postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public
# - Session pooler ("Shared Pooler", IPv4): port 5432, user postgres.PROJECTREF (not "postgres")
#   postgresql://postgres.PROJECTREF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?schema=public
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres?schema=public
#
# DIRECT_URL — migrations (`prisma migrate`). Prefer direct host when your network supports it:
# postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres?schema=public
# If db.* is unreachable (IPv4), point DIRECT_URL at the same Session pooler URI as DATABASE_URL.
DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres?schema=public

# Redis (BullMQ + rate limits)
# REDIS_URL=redis://localhost:6379
REDIS_URL=rediss://:fpLtdIberAhpRw6dgZP71ghgiBZcijnjCAzCaJFbP1Y=@snap-sell.redis.cache.windows.net:6380
#
# Azure App Service: there is no Redis on localhost. Use a managed cache reachable from the web app.
# Azure Cache for Redis — use TLS on port 6380 and the rediss:// scheme (note the double "s"):
#   REDIS_URL=rediss://:YOUR_ACCESS_KEY@YOUR_NAME.redis.cache.windows.net:6380
# If the key contains special characters, URL-encode it. In Azure Portal → your Redis → Networking,
# allow your App Service outbound IPs (App Service → Properties) or use appropriate VNet integration.
# Other hosts (Upstash, Redis Cloud, etc.): use the TLS URL they provide if it starts with rediss://.

# Legacy alias — optional; if set, falls back when SUPABASE_JWT_SECRET empty
JWT_SECRET=

# Marketplace session cookie encryption (32-byte key, base64-encoded)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COOKIE_ENCRYPTION_KEY=

# AI — Anthropic Claude only (snap-to-list vision, reply suggestions)
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=
ANTHROPIC_REPLY_MODEL=
# Optional — Flutter/mobile POST /api/listing/analyze. Defaults to ANTHROPIC_VISION_MODEL when unset.
LISTING_ANALYZE_MODEL=

# Optional: global API rate limit (requests per TTL window)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Playwright platforms: max operations per minute per user+marketplace
PLAYWRIGHT_RATE_LIMIT_POINTS=5
PLAYWRIGHT_RATE_LIMIT_DURATION_SEC=60

# Storage bucket for listing photos (create in Supabase Storage)
SUPABASE_LISTINGS_BUCKET=listings

# Webhook for POST /webhooks/sale-detected (required in production)
SALE_WEBHOOK_SECRET=
